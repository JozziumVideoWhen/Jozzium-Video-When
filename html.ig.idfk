<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Countdown Timer</title>
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@700&display=swap" rel="stylesheet">
    <style>
        body {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: 'League Spartan', sans-serif;
            background-color: black;
            color: white;
            font-size: 5em;
            position: relative;
            overflow: hidden; /* Prevent overflow of background */
        }
        #button-container {
            position: absolute;
            bottom: 20px; /* Move buttons to the bottom */
            display: flex;
            justify-content: center; /* Center buttons horizontally */
        }
        button {
            margin: 5px;
            padding: 15px 30px; /* Larger button size */
            font-size: 18px; /* Set font size to 18 pixels */
            cursor: pointer;
            background-color: #404040; /* Darker grey */
            color: white; /* White text */
            border: none;
            border-radius: 15px; /* Rounded corners */
            transition: background-color 0.3s;
            height: 60px; /* Increased height */
            width: 150px; /* Fixed width for consistency */
        }
        button:hover {
            background-color: #303030; /* Darker grey on hover */
        }
        #bgUploader {
            position: absolute;
            top: 20px; /* Position the file input at the top */
        }
    </style>
</head>
<body>
    <input type="file" id="bgUploader" accept="image/*,video/*" onchange="changeBackground(this)" />
    <div id="countdown"></div>

    <div id="button-container">
        <button onclick="changeTextColor()">Change Text Color</button>
        <button onclick="changeFont()">Change Font</button>
        <button onclick="resetBackground()">Reset Background</button>
    </div>

    <script>
        function updateCountdown() {
            const now = new Date();
            const targetDate = new Date('2026-03-04T15:00:00-05:00'); // 3 PM EST
            const diff = targetDate - now;

            if (diff <= 0) {
                document.getElementById('countdown').innerHTML = "Countdown Finished!";
                clearInterval(interval);
                return;
            }

            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);
            document.getElementById('countdown').innerHTML = `${hours}h ${minutes}m ${seconds}s`;
        }

        const interval = setInterval(updateCountdown, 1000);
        updateCountdown(); // Initial call to display countdown immediately

        function changeBackground(input) {
            const file = input.files[0];
            const reader = new FileReader();
            reader.onload = function(e) {
                document.body.style.backgroundImage = `url(${e.target.result})`;
                document.body.style.backgroundSize = 'cover';
                document.body.style.backgroundPosition = 'center';
            }
            if (file && (file.type.startsWith('image/') || file.type.startsWith('video/'))) {
                reader.readAsDataURL(file);
            }
        }

        function resetBackground() {
            document.body.style.backgroundImage = '';
        }

        function changeTextColor() {
            const colors = ['white', 'red', 'blue', 'green', 'yellow', 'pink', 'orange'];
            const currentColor = document.body.style.color;
            let newColor;
            do {
                newColor = colors[Math.floor(Math.random() * colors.length)];
            } while (newColor === currentColor);
            document.body.style.color = newColor;
        }

        function changeFont() {
            const fonts = ['League Spartan', 'Arial', 'Courier New', 'Georgia', 'Times New Roman', 'Verdana'];
            const currentFont = document.body.style.fontFamily;
            let newFont;
            do {
                newFont = fonts[Math.floor(Math.random() * fonts.length)];
            } while (newFont === currentFont);
            document.body.style.fontFamily = newFont;
        }
    </script>
</body>
</html>
